\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Final benchmark comparison on the 100-document dataset. Tuned ACOM exceeds PCA on neighborhood preservation and trustworthiness, but t-SNE and UMAP remain stronger overall on the benchmark. Higher is better for neighborhood preservation, trustworthiness, and silhouette; lower is better for stress.\relax }}{5}{table.caption.13}\protected@file@percent }
\newlabel{tab:main-comparison}{{3}{5}{Final benchmark comparison on the 100-document dataset. Tuned ACOM exceeds PCA on neighborhood preservation and trustworthiness, but t-SNE and UMAP remain stronger overall on the benchmark. Higher is better for neighborhood preservation, trustworthiness, and silhouette; lower is better for stress.\relax }{table.caption.13}{}}
