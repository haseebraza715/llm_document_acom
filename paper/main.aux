\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Baseline vs. Tuned ACOM}{3}{subsection.3.2}\protected@file@percent }
\newlabel{sec:baseline-vs-tuned}{{3.2}{3}{Baseline vs. Tuned ACOM}{subsection.3.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Baseline versus tuned ACOM on the 100-document benchmark. The baseline grid (A) has neighborhood preservation 0.134 and trustworthiness 0.567, while the tuned grid (B) reaches 0.367 and 0.787. The improvement corresponds to wider swap search followed by annealed acceptance.\relax }}{4}{figure.caption.9}\protected@file@percent }
\newlabel{fig:baseline-vs-tuned}{{2}{4}{Baseline versus tuned ACOM on the 100-document benchmark. The baseline grid (A) has neighborhood preservation 0.134 and trustworthiness 0.567, while the tuned grid (B) reaches 0.367 and 0.787. The improvement corresponds to wider swap search followed by annealed acceptance.\relax }{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Variant Sweep and Model Selection}{4}{subsection.3.3}\protected@file@percent }
\newlabel{sec:variant-sweep}{{3.3}{4}{Variant Sweep and Model Selection}{subsection.3.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Roman-numeral labels used for the ACOM variant sweep in Figure\nonbreakingspace \ref  {fig:variant-comparison}.\relax }}{4}{table.caption.11}\protected@file@percent }
