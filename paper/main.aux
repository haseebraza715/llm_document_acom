\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces ACOM variant sweep used for model selection. The baseline row is the untuned configuration; the tuned row combines wider swap search with annealed acceptance and gives the strongest result.\relax }}{4}{table.caption.12}\protected@file@percent }
\newlabel{tab:acom-ablation}{{2}{4}{ACOM variant sweep used for model selection. The baseline row is the untuned configuration; the tuned row combines wider swap search with annealed acceptance and gives the strongest result.\relax }{table.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ACOM variant sweep. Wider search produces the first major gain over the baseline, and annealed acceptance yields the strongest final result. Variant labels I--VII are defined in Table\nonbreakingspace \ref  {tab:variant-labels}.\relax }}{5}{figure.caption.10}\protected@file@percent }
\newlabel{fig:variant-comparison}{{3}{5}{ACOM variant sweep. Wider search produces the first major gain over the baseline, and annealed acceptance yields the strongest final result. Variant labels I--VII are defined in Table~\ref {tab:variant-labels}.\relax }{figure.caption.10}{}}
